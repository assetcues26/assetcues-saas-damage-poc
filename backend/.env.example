# Bind 0.0.0.0 so phones on same Wi‑Fi can reach the API (see serve.py)
API_HOST=0.0.0.0
API_PORT=8000

GEMINI_API_KEY=your-gemini-api-key

# Stable Gemini 3.1 Flash — fast and cost-efficient (no thinking mode).
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_THINKING_ENABLED=false
GEMINI_THINKING_BUDGET=2048

GEMINI_ANALYZE_TEMPERATURE=0.0

MIN_IMAGES=1
MAX_IMAGES=10
# Keep equal to MAX_IMAGES — collage and multi both accept the full batch (up to 10).
MAX_IMAGES_LATENCY_MODE=10
MAX_IMAGE_SIZE_MB=15
MAX_PREPROCESS_EDGE_PX=2048

# Detail vs cost lever (low | medium | high). ultra_high is clamped to high by the SDK.
MEDIA_RESOLUTION_COLLAGE=high
MEDIA_RESOLUTION_MULTI=high

# Cost estimate pricing (USD per 1M tokens) — match your GEMINI_MODEL
GEMINI_INPUT_USD_PER_1M=0.25
GEMINI_OUTPUT_USD_PER_1M=1.50

# USD->INR. Production: FX_ENABLED=true (live rate, cached; falls back to USD_TO_INR_FALLBACK).
FX_ENABLED=true
FX_API_URL=https://api.frankfurter.dev/v1/latest
FX_CACHE_TTL_SECONDS=3600
FX_TIMEOUT_SECONDS=4.0
USD_TO_INR_FALLBACK=83.0
USD_TO_GBP_FALLBACK=0.79

# Optional: path to valuation JSON (category baselines, depreciation, rules). Default: per-market file in app/data/
REFERENCE_PRICES_PATH=

# Multi-market valuation (IN / US / GB). Set false for instant rollback to India-only.
MULTI_MARKET_ENABLED=true

RATE_LIMIT_PER_MINUTE=60
GEMINI_MAX_RETRIES=2
# GEMINI_HARD_TIMEOUT_SECONDS=0 means no asyncio cap on Gemini (default)
GEMINI_TIMEOUT_SECONDS=30
GEMINI_HARD_TIMEOUT_SECONDS=0

# ANALYSIS_TARGET_MS=0 disables slow-request warning threshold
ANALYSIS_TARGET_MS=0
VALUATION_CONFIDENCE_THRESHOLD=0.75
PROMPT_VERSION=v2

# Client defaults (change here — no code deploy needed for region switch)
# MARKET_REGION: default valuation region when a request omits market_region (IN | US | GB)
DEFAULT_LOCALE=en-IN
MARKET_REGION=IN
DISPLAY_CURRENCY=INR

REVIEW_CONFIDENCE_THRESHOLD=0.65
FIELD_CONFIDENCE_THRESHOLD=0.5

# V6 ERP demo endpoints (/v6/demo/*). Default off for production.
V6_DEMO_ENABLED=false

# Supabase persistence (backend only — never put service role key in frontend)
SUPABASE_URL=https://byftlfblysvlmqpcqfnu.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=analysis-images
SUPABASE_SIGNED_URL_TTL_SECONDS=3600
SUPABASE_PERSIST_ENABLED=false
DEMO_USER_ID=100
# Optional shared secret for GET/DELETE /v1/history* (sent as X-Demo-Key header)
DEMO_API_KEY=
HISTORY_RATE_LIMIT_PER_MINUTE=120

# Cross-device QR capture sessions (requires SUPABASE_PERSIST_ENABLED)
CAPTURE_SESSION_ENABLED=false
CAPTURE_SESSION_TTL_HOURS=2
CAPTURE_STORAGE_BUCKET=capture-images
SESSION_RATE_LIMIT_PER_MINUTE=120
# Optional — used to build qr_url in API responses when set
FRONTEND_BASE_URL=

# SaaS asset register module (requires SUPABASE_PERSIST_ENABLED)
SAAS_ASSETS_ENABLED=false
SAAS_ASSETS_STORAGE_BUCKET=saas-asset-images
SAAS_ASSET_CREATE_SESSION_TTL_MINUTES=30
SAAS_ASSETS_RATE_LIMIT_PER_MINUTE=120
TAGGING_AI_API_URL=https://taggingai.vercel.app/api/asset_analysis
TAGGING_AI_TIMEOUT_SECONDS=90
