# Copy to .env.local for local dev. In Vercel: Project → Settings → Environment Variables.

# Asset analysis API (defaults to production backend if unset)
VITE_ASSET_ANALYSIS_API_BASE=


VITE_APP_BASE_URL=

# V6 ERP demo UI (/v6/*). Must match backend V6_DEMO_ENABLED for full flow.
VITE_V6_DEMO_ENABLED=false

# Optional — must match backend DEMO_API_KEY when set
VITE_DEMO_API_KEY=

# Default market for new visitors (IN | US | GB). User picker overrides and persists in localStorage.
VITE_DEFAULT_MARKET_REGION=IN

# Cross-device QR capture (requires backend CAPTURE_SESSION_ENABLED + HTTPS VITE_APP_BASE_URL)
VITE_CAPTURE_SESSION_ENABLED=true

# AssetCues dashboard module (dashboard at /, POC scan at /poc)
VITE_SAAS_MODULE_ENABLED=false

# Supabase (publishable key — safe for frontend)
VITE_SUPABASE_URL=https://byftlfblysvlmqpcqfnu.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_ANON_KEY=your-publishable-key
